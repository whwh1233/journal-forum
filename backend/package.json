{
  "name": "journal-forum-backend",
  "version": "0.1.2",
  "description": "Backend service for pubWhere",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "start:test": "cross-env NODE_ENV=test node server.js",
    "seed:test": "cross-env NODE_ENV=test node scripts/seedData.js",
    "seed": "node scripts/seed.js",
    "seed:reset": "node scripts/seed.js --reset",
    "migrate:tags": "node scripts/migratePostTagCategory.js",
    "migrate:tags:dry": "node scripts/migratePostTagCategory.js --dry-run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.18.2",
    "nanoid": "^3.3.11",
    "node-cron": "^4.2.1",
    "sequelize": "^6.37.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.47.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
